# EduPath AI — Environment Variables
# Copy this file to .env and fill in your values

# ═══ LLM Configuration ═══
# By default, EduPath uses our GRPO fine-tuned model on HuggingFace.
# No API key is required for basic usage (public model).

# (Optional) HuggingFace token for higher rate limits
HF_TOKEN=your_hf_token_here

# (Optional) Override the default model/endpoint
# API_BASE_URL=https://api-inference.huggingface.co/v1
# MODEL_NAME=degree-checker-01/edupath-grpo-tutor

# (Optional) Use Groq instead (faster inference)
# API_BASE_URL=https://api.groq.com/openai/v1
# MODEL_NAME=llama-3.1-70b-versatile
# GROQ_API_KEY=your_groq_key_here

# ═══ Database (Optional) ═══
# SUPABASE_URL=your_supabase_url
# SUPABASE_KEY=your_supabase_key

# ═══ Backend Configuration ═══
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ═══ Frontend Configuration ═══
NEXT_PUBLIC_API_URL=http://localhost:8000
